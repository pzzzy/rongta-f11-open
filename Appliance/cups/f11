#!/bin/bash
set -euo pipefail
PATH=/usr/local/lib/f11:/usr/bin:/bin
F11D=${F11D:-/usr/local/lib/f11/f11d}
F11_SPOOL=${F11_SPOOL:-/var/spool/f11}
F11_LOCK=${F11_LOCK:-/run/lock/f11-print.lock}
if [[ $# -eq 0 ]]; then
  echo 'direct f11:/ "Rongta F11" "Rongta F11 Open Driver" "MFG:Rongta;MDL:F11;"'
  exit 0
fi
[[ -x "$F11D" ]] || { echo "ERROR: missing f11d: $F11D" >&2; exit 1; }
[[ -d "$F11_SPOOL" && -w "$F11_SPOOL" ]] || { echo "ERROR: spool is not writable: $F11_SPOOL" >&2; exit 1; }
[[ $# -ge 5 ]] || exit 1
JOB=${1//[^0-9]/}
COPIES=${4//[^0-9]/}
[[ $COPIES =~ ^[0-9]+$ && $COPIES -ge 1 && $COPIES -le 255 ]] || { echo 'ERROR: invalid copies' >&2; exit 1; }
TMP=$(mktemp -d "$F11_SPOOL/job-${JOB:-unknown}.XXXXXX")
trap 'rm -rf "$TMP"' EXIT
exec 9>"$F11_LOCK"
flock -x 9
if [[ $# -ge 6 && -n ${6:-} ]]; then
  [[ $(stat -c %s "$6") -le 67108864 ]] || { echo 'ERROR: job too large' >&2; exit 1; }
  cp -- "$6" "$TMP/input.pdf"
else
  head -c 67108865 >"$TMP/input.pdf"
  [[ $(stat -c %s "$TMP/input.pdf") -le 67108864 ]] || { echo 'ERROR: job too large' >&2; exit 1; }
fi
set +e
timeout 20 qpdf "$TMP/input.pdf" "$TMP/normalized.pdf" >&2
QPDF_RC=$?
set -e
[[ $QPDF_RC -eq 0 || $QPDF_RC -eq 3 ]] || { echo "ERROR: invalid PDF (qpdf status $QPDF_RC)" >&2; exit 1; }
timeout 20 qpdf --check "$TMP/normalized.pdf" >/dev/null
PAGES=$(timeout 20 qpdf --show-npages "$TMP/normalized.pdf")
[[ $PAGES =~ ^[0-9]+$ && $PAGES -ge 1 && $PAGES -le 20 ]] || { echo 'ERROR: page count' >&2; exit 1; }
for ((page=1; page<=PAGES; page++)); do
  timeout 60 pdftoppm -f "$page" -l "$page" -singlefile -r 203 -gray -scale-to-x 1664 -scale-to-y 2233 "$TMP/normalized.pdf" "$TMP/page"
  "$F11D" encode-pgm "$TMP/page.pgm" "$TMP/page.f11"
  for ((copy=1; copy<=COPIES; copy++)); do
    if [[ ${F11_DRY_RUN:-0} == 1 ]]; then
      "$F11D" validate "$TMP/page.f11"
    else
      "$F11D" send "$TMP/page.f11"
    fi
  done
done
exit 0
